PORT=5001
CLIENT_ORIGIN=http://localhost:5173

# Local development can use SQLite:
DATABASE_PATH=./glucosa.db

# Production should use Neon/PostgreSQL. When DATABASE_URL exists, it takes priority over DATABASE_PATH.
DATABASE_URL=
DATABASE_SSL=true

JWT_SECRET=change-this-secret

# Optional: enables automatic glucose reading from meter photos.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini
